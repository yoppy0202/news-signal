# news-signal 環境変数テンプレート
# 実運用時は .env にコピーして値をセット。GitHub Actions では Secrets に登録。

# Telegram 通知（Phase 4 で有効化）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# TELEGRAM_TOPIC_NEWS_IMPACT: 通知先のスレッド/トピック ID（未設定時はメイン）
TELEGRAM_TOPIC_NEWS_IMPACT=

# DB パス（省略可。既定: ./data/news_signal.sqlite3）
# NEWS_SIGNAL_DB=

# Telegram コレクター（Phase 5）
# my.telegram.org でアプリを作成して取得
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# TELEGRAM_PHONE: ローカル初回認証時のみ使用（+81...形式）
TELEGRAM_PHONE=
# TELEGRAM_SESSION: scripts/telegram_auth.py で生成したセッション文字列
# GitHub Actions では Secrets に登録。ローカルでは .env に記述可
TELEGRAM_SESSION=

# Google Sheets 連携（Phase 2 以降）
# SHEETS_ID: スプレッドシートの ID（URL の /d/XXXXX/edit の XXXXX 部分）
SHEETS_ID=
# GOOGLE_CREDENTIALS: サービスアカウント credentials.json の内容を1行JSONに変換したもの
# ローカル開発では credentials.json をプロジェクトルートに置いても可
GOOGLE_CREDENTIALS=
