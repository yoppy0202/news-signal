# news-signal 環境変数テンプレート
# 実運用時は .env にコピーして値をセット。GitHub Actions では Secrets に登録。

# Telegram 通知（Phase 1 以降で使用）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# DB パス（省略可。既定: ./data/news_signal.sqlite3）
# NEWS_SIGNAL_DB=

# Google Sheets 連携（Phase 2 以降）
# SHEETS_ID: スプレッドシートの ID（URL の /d/XXXXX/edit の XXXXX 部分）
SHEETS_ID=
# GOOGLE_CREDENTIALS: サービスアカウント credentials.json の内容を1行JSONに変換したもの
# ローカル開発では credentials.json をプロジェクトルートに置いても可
GOOGLE_CREDENTIALS=
